{
  "name": "discord-clone",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace apps/api\" \"npm run dev --workspace apps/web\"",
    "dev:api": "npm run dev --workspace apps/api",
    "dev:web": "npm run dev --workspace apps/web",
    "build": "npm run build --workspaces",
    "lint": "eslint .",
    "typecheck": "npm run typecheck --workspaces",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "ui:smoke": "node scripts/ui-smoke.mjs",
    "db:generate": "npm run db:generate --workspace apps/api",
    "db:push": "npm run db:push --workspace apps/api",
    "db:migrate": "npm run db:migrate --workspace apps/api",
    "db:seed": "npm run db:seed --workspace apps/api"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "concurrently": "latest",
    "eslint": "latest",
    "globals": "latest",
    "prettier": "latest",
    "puppeteer-core": "^25.1.0",
    "typescript": "latest",
    "typescript-eslint": "latest"
  }
}
