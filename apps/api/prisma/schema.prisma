generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ONLINE
  OFFLINE
  IDLE
  DND
  INVISIBLE
}

enum ChannelType {
  TEXT
  VOICE
}

enum MemberKind {
  OWNER
  MEMBER
}

enum FriendStatus {
  PENDING
  ACCEPTED
  REJECTED
  BLOCKED
}

model User {
  id                        String                     @id @default(cuid())
  email                     String                     @unique
  username                  String                     @unique
  displayName               String
  passwordHash              String
  avatarUrl                 String?
  bio                       String?
  status                    UserStatus                 @default(OFFLINE)
  emailVerifiedAt           DateTime?
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  sessions                  Session[]
  emailVerificationTokens   EmailVerificationToken[]
  memberships               ServerMember[]
  messages                  Message[]
  messagePins               MessagePin[]               @relation("MessagePins")
  readStates                ReadState[]
  notificationPreferences   NotificationPreference[]
  pushSubscriptions         PushSubscription[]
  pushNotificationThrottles PushNotificationThrottle[]
  auditLogs                 AuditLog[]                 @relation("AuditActor")
  createdServers            Server[]                   @relation("ServerOwner")
  sentFriendRequests        FriendRequest[]            @relation("FriendRequester")
  receivedFriendRequests    FriendRequest[]            @relation("FriendReceiver")
  conversations             DirectConversationMember[]
  directMessages            DirectMessage[]
  createdThreads            Thread[]                   @relation("ThreadCreator")
  threadParticipants        ThreadParticipant[]
  directReadStates          DirectReadState[]
  notifications             Notification[]              @relation("NotificationUser")
  actedNotifications        Notification[]              @relation("NotificationActor")
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model Session {
  id          String    @id @default(cuid())
  userId      String
  refreshHash String
  userAgent   String?
  revokedAt   DateTime?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Server {
  id                      String                   @id @default(cuid())
  name                    String
  description             String?
  avatarUrl               String?
  ownerId                 String
  deletedAt               DateTime?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  owner                   User                     @relation("ServerOwner", fields: [ownerId], references: [id])
  members                 ServerMember[]
  roles                   Role[]
  channels                Channel[]
  invites                 Invite[]
  notificationPreferences NotificationPreference[]
  auditLogs               AuditLog[]
}

model ServerMember {
  id                  String                      @id @default(cuid())
  userId              String
  serverId            String
  kind                MemberKind                  @default(MEMBER)
  nickname            String?
  joinedAt            DateTime                    @default(now())
  user                User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  server              Server                      @relation(fields: [serverId], references: [id], onDelete: Cascade)
  roles               MemberRole[]
  permissionOverrides ChannelPermissionOverride[]

  @@unique([userId, serverId])
}

model Role {
  id                  String                      @id @default(cuid())
  serverId            String
  name                String
  color               String?
  position            Int                         @default(0)
  permissions         String[]                    @default([])
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt
  server              Server                      @relation(fields: [serverId], references: [id], onDelete: Cascade)
  members             MemberRole[]
  permissionOverrides ChannelPermissionOverride[]

  @@unique([serverId, name])
}

model MemberRole {
  memberId String
  roleId   String
  member   ServerMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  role     Role         @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([memberId, roleId])
}

model Channel {
  id                        String                      @id @default(cuid())
  serverId                  String
  name                      String
  type                      ChannelType                 @default(TEXT)
  topic                     String?
  avatarUrl                 String?
  position                  Int                         @default(0)
  isPrivate                 Boolean                     @default(false)
  createdAt                 DateTime                    @default(now())
  updatedAt                 DateTime                    @updatedAt
  server                    Server                      @relation(fields: [serverId], references: [id], onDelete: Cascade)
  messages                  Message[]
  threads                   Thread[]
  pins                      MessagePin[]
  permissionOverrides       ChannelPermissionOverride[]
  readStates                ReadState[]
  notificationPreferences   NotificationPreference[]
  pushNotificationThrottles PushNotificationThrottle[]

  @@unique([serverId, name])
}

model ChannelPermissionOverride {
  id        String        @id @default(cuid())
  channelId String
  roleId    String?
  memberId  String?
  allow     String[]      @default([])
  deny      String[]      @default([])
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  channel   Channel       @relation(fields: [channelId], references: [id], onDelete: Cascade)
  role      Role?         @relation(fields: [roleId], references: [id], onDelete: Cascade)
  member    ServerMember? @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([channelId])
  @@index([roleId])
  @@index([memberId])
}

model Message {
  id               String              @id @default(cuid())
  channelId        String
  serverId         String
  authorId         String
  content          String
  replyToMessageId String?
  threadId         String?
  editedAt         DateTime?
  deletedAt        DateTime?
  createdAt        DateTime            @default(now())
  channel          Channel             @relation(fields: [channelId], references: [id], onDelete: Cascade)
  thread           Thread?             @relation("ThreadMessages", fields: [threadId], references: [id], onDelete: Cascade)
  threadRoot       Thread?             @relation("ThreadRoot")
  author           User                @relation(fields: [authorId], references: [id])
  attachments      MessageAttachment[]
  reactions        MessageReaction[]
  pin              MessagePin?

  @@index([channelId, createdAt])
  @@index([threadId, createdAt])
}

model Thread {
  id            String              @id @default(cuid())
  channelId     String
  serverId      String
  rootMessageId String              @unique
  createdById   String
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  channel       Channel             @relation(fields: [channelId], references: [id], onDelete: Cascade)
  rootMessage   Message             @relation("ThreadRoot", fields: [rootMessageId], references: [id], onDelete: Cascade)
  createdBy     User                @relation("ThreadCreator", fields: [createdById], references: [id])
  messages      Message[]           @relation("ThreadMessages")
  participants  ThreadParticipant[]

  @@index([channelId, updatedAt])
  @@index([serverId])
}

model ThreadParticipant {
  threadId   String
  userId     String
  lastReadAt DateTime?
  joinedAt   DateTime @default(now())
  thread     Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([threadId, userId])
  @@index([userId])
}

model MessageAttachment {
  id        String   @id @default(cuid())
  messageId String
  fileName  String
  mimeType  String
  byteSize  Int
  url       String
  createdAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model MessageReaction {
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@id([messageId, userId, emoji])
}

model MessagePin {
  messageId  String   @id
  channelId  String
  pinnedById String
  createdAt  DateTime @default(now())
  message    Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  channel    Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  pinnedBy   User     @relation("MessagePins", fields: [pinnedById], references: [id])

  @@index([channelId, createdAt])
}



model ReadState {
  id                String   @id @default(cuid())
  userId            String
  channelId         String
  lastReadMessageId String?
  lastReadAt        DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel           Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([userId, channelId])
  @@index([channelId, lastReadAt])
}

model NotificationPreference {
  id             String   @id @default(cuid())
  userId         String
  serverId       String?
  channelId      String?
  muted          Boolean  @default(false)
  mentionOnly    Boolean  @default(false)
  desktopEnabled Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  server         Server?  @relation(fields: [serverId], references: [id], onDelete: Cascade)
  channel        Channel? @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([userId, serverId])
  @@index([userId, channelId])
}

model PushSubscription {
  id         String   @id @default(cuid())
  userId     String
  endpoint   String   @unique
  p256dh     String
  auth       String
  deviceName String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PushNotificationThrottle {
  id         String   @id @default(cuid())
  userId     String
  channelId  String
  lastSentAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel    Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([userId, channelId])
  @@index([channelId])
}

model AuditLog {
  id        String   @id @default(cuid())
  serverId  String
  actorId   String
  action    String
  targetId  String?
  metadata  Json?
  createdAt DateTime @default(now())
  server    Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  actor     User     @relation("AuditActor", fields: [actorId], references: [id])

  @@index([serverId, createdAt])
  @@index([actorId, createdAt])
}

model Invite {
  id        String    @id @default(cuid())
  code      String    @unique
  serverId  String
  channelId String?
  creatorId String
  maxUses   Int?
  usedCount Int       @default(0)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  server    Server    @relation(fields: [serverId], references: [id], onDelete: Cascade)
}

model FriendRequest {
  id          String       @id @default(cuid())
  requesterId String
  receiverId  String
  status      FriendStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  requester   User         @relation("FriendRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  receiver    User         @relation("FriendReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([requesterId, receiverId])
}

model DirectConversation {
  id         String                     @id @default(cuid())
  createdAt  DateTime                   @default(now())
  updatedAt  DateTime                   @updatedAt
  members    DirectConversationMember[]
  messages   DirectMessage[]
  readStates DirectReadState[]
}

model DirectConversationMember {
  conversationId String
  userId         String
  conversation   DirectConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
}

model DirectMessage {
  id             String             @id @default(cuid())
  conversationId String
  authorId       String
  content        String
  editedAt       DateTime?
  deletedAt      DateTime?
  createdAt      DateTime           @default(now())
  conversation   DirectConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  author         User               @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([authorId])
  @@index([conversationId, createdAt])
}

model DirectReadState {
  id                String             @id @default(cuid())
  userId            String
  conversationId    String
  lastReadMessageId String?
  lastReadAt        DateTime           @default(now())
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation      DirectConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([userId, conversationId])
  @@index([conversationId, lastReadAt])
}

model Notification {
  id             String              @id @default(cuid())
  userId         String
  type           String
  title          String
  body           String?
  actorId        String?
  channelId      String?
  messageId      String?
  conversationId String?
  readAt         DateTime?
  createdAt      DateTime            @default(now())
  user           User                @relation("NotificationUser", fields: [userId], references: [id], onDelete: Cascade)
  actor          User?               @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([userId, readAt, createdAt])
  @@index([conversationId])
  @@index([channelId])
  @@index([messageId])
}
